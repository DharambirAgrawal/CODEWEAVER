# Server
PORT=4000

# LLM Provider: gemini | groq | openrouter | nvidia
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=your_groq_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
NVIDIA_API_KEY=your_nvidia_key_here
OPENROUTER_MODEL=openrouter/free
# Optional: comma-separated fallback list (overrides OPENROUTER_MODEL)
# OPENROUTER_MODELS=model-a,model-b,model-c
# Optional: comma-separated NVIDIA model list
# NVIDIA_MODELS=model-a,model-b,model-c
# If primary provider fails (429/503/etc), try these in order (requires keys set)
# LLM_FALLBACK_PROVIDERS=groq,openrouter
# Retries per provider before switching (default 3)
# LLM_RETRY_ATTEMPTS=3

# Skills injected into prompts (skills/index.json). Set to 0 to disable.
# SKILLS_ENABLED=1
# SKILL_MAX_CHARS=12000

# Task analyzer (unified prompt refine + parse). Set to 0 to use local fallback.
# TASK_ANALYZER_ENABLED=1

# Local single-prompt runner
# CW_PROMPT_FILE=tests/prompt.py
# CW_OUTPUT_DIR=tests/output
# CW_CODE_GEN_MAX_TOKENS=6000
# CW_PYTHON=venv/bin/python  # relative paths resolve from repo root
# Parallel best-of-N model race per generation step (local runner)
# LLM_PARALLEL_ENABLED=1
# LLM_PARALLEL_MODELS=3
# LLM_PARALLEL_TIMEOUT_MS=35000
# LLM_PARALLEL_SCOPE=all  # all | provider (provider = primary only)

# Execify
EXECIFY_BASE_URL=http://localhost:3000
EXECIFY_API_KEY=
# EXECIFY_TIMEOUT_MS=60000

# LLM request timeout (all providers)
# LLM_TIMEOUT_MS=60000

# Orchestrator limits
MAX_RETRIES=5
MAX_CHUNKS=10
CHUNK_TIMEOUT_MS=30000
